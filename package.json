{
  "name": "pi-skill-arg-hints",
  "version": "1.1.1",
  "description": "Inline argument-hint placeholders for Pi skill and prompt template slash commands.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "skills",
    "prompt-templates",
    "slash-commands"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MiguelMachado-dev/pi-skill-arg-hints.git"
  },
  "bugs": {
    "url": "https://github.com/MiguelMachado-dev/pi-skill-arg-hints/issues"
  },
  "homepage": "https://github.com/MiguelMachado-dev/pi-skill-arg-hints#readme",
  "packageManager": "pnpm@8.15.9",
  "type": "module",
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
